<%- include ('partials/header') %>

<h1 class="d-flex justify-content-center muted mb-3" style="letter-spacing: 4px; text-transform: uppercase;"><%= category.name %> recipes</h1>

<main class="d-flex text-center px-5 mb-5">
    <article class="row g-3 justify-content-center">
        <% for (const recipe of recipes) { %>
            <div class="col-md-6 col-xl-4 col-xxl-3 px-4">
                <figure>
                    <img style="padding-top: 8px; width: 100%; height: 400px; object-fit: cover; box-sizing: border-box;"
                        src="<%= recipe.image %>" alt="">
                    <div class="fs-4 pt-2 ps-7 pe-7 pb-2"
                        style="text-decoration: none; color: inherit;">
                        <a class="fs-4 ps-4 pe-4 pb-1" style="text-decoration: none; color: inherit; background-color: rgba(238, 210, 176, 0.5); " href="<%=recipe.link%>" target="_blank"><%= recipe.title %></a>
                        <div class="text-secondary" style="font-size: small; font-style: italic;"><%= recipe.website %></div>
                        <div class="text-secondary mt-2" style="font-size: small;"><%= recipe.body %></div>
                        <div class="text-secondary mt-2" style="font-size: small;">submitted by <%= recipe.user.username %></div>
                    </div>
                </figure>
            </div>
        <% } %>                  
    </article>
</main>


<%- include ('partials/footer') %>